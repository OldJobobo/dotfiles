#!/usr/bin/env bash
set -euo pipefail

raw_name="${1:-}"
if [[ -z "$raw_name" ]]; then
  echo "usage: $(basename "$0") <theme-name>" >&2
  exit 1
fi

base_name="$raw_name"
base_name="${base_name#omarchy-}"
base_name="${base_name%-theme}"

if [[ -z "$base_name" ]]; then
  echo "error: theme name resolves to empty" >&2
  exit 1
fi

theme_dir="omarchy-${base_name}-theme"
theme_path="$(pwd)/${theme_dir}"
link_root="${HOME}/.config/omarchy/themes"
link_path="${link_root}/${base_name}"

if [[ ! -d "$theme_path" ]]; then
  echo "error: theme directory not found: ${theme_path}" >&2
  exit 1
fi

mkdir -p "$link_root"
ln -sfn "$theme_path" "$link_path"
echo "linked ${link_path} -> ${theme_path}"
