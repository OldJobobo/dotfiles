#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${TM_AWWW_DEBUG:-}" ]]; then
  set -x
else
  exec >/dev/null 2>&1
fi

if [[ -n "${TM_AWWW_DEBUG:-}" && -z "${TM_AWWW_LOG:-}" ]]; then
  TM_AWWW_LOG="$HOME/.cache/tm-next-wallpaper-awww.log"
fi

log_line() {
  if [[ -n "${TM_AWWW_LOG:-}" ]]; then
    mkdir -p "$(dirname "$TM_AWWW_LOG")"
    printf '%s %s\n' "$(date +'%Y-%m-%d %H:%M:%S')" "$*" >>"$TM_AWWW_LOG"
  fi
}

notify_cycle() {
  local title="$1"
  local body="$2"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send --app-name=tm-next-wallpaper --urgency=normal \
      "$title" "$body" >/dev/null 2>&1 || true
  fi
}

if [[ -z "${XDG_RUNTIME_DIR:-}" ]]; then
  XDG_RUNTIME_DIR="/run/user/$(id -u)"
  export XDG_RUNTIME_DIR
  log_line "set XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR"
fi

if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
  for sock in "$XDG_RUNTIME_DIR"/wayland-*; do
    if [[ -S "$sock" ]]; then
      WAYLAND_DISPLAY="${sock##*/}"
      export WAYLAND_DISPLAY
      log_line "set WAYLAND_DISPLAY=$WAYLAND_DISPLAY"
      break
    fi
  done
fi

theme_name_file="$HOME/.config/omarchy/current/theme.name"
bg_link="$HOME/.config/omarchy/current/background"

theme_name=""
if [[ -f "$theme_name_file" ]]; then
  theme_name="$(<"$theme_name_file")"
  theme_name="$(echo "$theme_name" | xargs)"
fi

theme_bg_dir="$HOME/.config/omarchy/current/theme/backgrounds"
user_bg_dir="$HOME/.config/omarchy/backgrounds/$theme_name"
include_live="${JOBOWALLS_CYCLE_INCLUDE_LIVE:-1}"

find_expr=(
  -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp"
  -o -iname "*.bmp" -o -iname "*.gif"
)

if [[ "$include_live" != "0" ]]; then
  find_expr+=(
    -o -iname "*.mp4" -o -iname "*.webm" -o -iname "*.mkv"
    -o -iname "*.mov" -o -iname "*.avi"
  )
fi

mapfile -d '' -t wallpapers < <(
  find -L "$user_bg_dir" "$theme_bg_dir" -maxdepth 1 -type f \
    \( "${find_expr[@]}" \) \
    -print0 2>/dev/null | sort -z
)

if [[ ${#wallpapers[@]} -eq 0 ]]; then
  log_line "no supported wallpapers found in background directories"
  exit 1
fi

current="$(readlink -f "$bg_link" 2>/dev/null || true)"
mode="${JOBOWALLS_CYCLE_MODE:-next}"

next=""
case "$mode" in
  shuffle)
    if [[ ${#wallpapers[@]} -eq 1 ]]; then
      next="${wallpapers[0]}"
    else
      current_index=-1
      if [[ -n "$current" ]]; then
        for i in "${!wallpapers[@]}"; do
          if [[ "${wallpapers[$i]}" == "$current" ]]; then
            current_index="$i"
            break
          fi
        done
      fi
      random_index=$((RANDOM % ${#wallpapers[@]}))
      if [[ "$random_index" -eq "$current_index" ]]; then
        random_index=$(((random_index + 1) % ${#wallpapers[@]}))
      fi
      next="${wallpapers[$random_index]}"
    fi
    ;;
  next|"")
    if [[ -n "$current" ]]; then
      for i in "${!wallpapers[@]}"; do
        if [[ "${wallpapers[$i]}" == "$current" ]]; then
          next="${wallpapers[$(((i + 1) % ${#wallpapers[@]}))]}"
          break
        fi
      done
    fi
    if [[ -z "$next" ]]; then
      next="${wallpapers[0]}"
    fi
    ;;
  *)
    log_line "unsupported JOBOWALLS_CYCLE_MODE=$mode"
    exit 1
    ;;
esac

ln -sf "$next" "$bg_link"
log_line "selected $next"

if ! command -v jobowalls >/dev/null 2>&1; then
  log_line "jobowalls not found in PATH"
  notify_cycle "JoboWalls not available" "Wallpaper cycle skipped because jobowalls is not in PATH."
  exit 1
fi

monitor="${JOBOWALLS_CYCLE_MONITOR:-all}"
ext="${next##*.}"
ext="${ext,,}"

cmd=(jobowalls set "$next" --monitor "$monitor")
case "$ext" in
  jpg|jpeg|png|webp|bmp|gif)
    static_backend="${JOBOWALLS_CYCLE_STATIC_BACKEND:-awww}"
    if [[ "$static_backend" != "auto" ]]; then
      cmd+=(--backend "$static_backend")
    fi
    ;;
esac

if ! output="$("${cmd[@]}" 2>&1)"; then
  log_line "jobowalls set failed: $output"
  notify_cycle "Wallpaper cycle failed" "$output"
  exit 1
fi

log_line "jobowalls set succeeded: $output"
